# Copier vers /var/www/blog-seydou/backend/.env sur le serveur
# chmod 600 backend/.env

NODE_ENV=production
PORT=5000
API_URL=https://backend-blog.tech-xuma.com
CLIENT_URL=https://blog.tech-xuma.com

DATABASE_URL="postgresql://blog_user:MOT_DE_PASSE@127.0.0.1:5432/blog_seydou?schema=public"

JWT_SECRET=GENERER_UNE_CLE_LONGUE_ET_ALEATOIRE
JWT_EXPIRES_IN=24h

UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Blog UCAD <no-reply@tech-xuma.com>"
ADMIN_EMAIL=admin@tech-xuma.com
