# Copier ce fichier en .env et renseigner les valeurs
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/blog_ucad?schema=public"

JWT_SECRET=changez_cette_cle_secrete
JWT_EXPIRES_IN=24h
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCK_MINUTES=15
AUTH_RESET_TTL_MIN=30
AUTH_VERIFY_TTL_HOURS=48
REFRESH_COOKIE_NAME=ucad_refresh

UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Blog UCAD <no-reply@blog-ucad.sn>"
ADMIN_EMAIL=admin@example.com
